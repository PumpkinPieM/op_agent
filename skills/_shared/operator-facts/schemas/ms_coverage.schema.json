{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "operator-facts ms_coverage row",
  "type": "object",
  "required": [
    "coverage_key",
    "op",
    "primitive",
    "aclnn",
    "dispatch_kind"
  ],
  "properties": {
    "coverage_key": {
      "type": "string",
      "description": "Primary key, composed from op and primitive."
    },
    "op": {
      "type": "string"
    },
    "primitive": {
      "type": "string"
    },
    "op_branch": {
      "type": "string"
    },
    "op_yaml_path": {
      "type": "string"
    },
    "class_name": {
      "type": "string"
    },
    "dispatch_enable": {
      "type": "string",
      "enum": [
        "True",
        "False",
        "true",
        "false"
      ]
    },
    "dispatch_kind": {
      "type": "string",
      "enum": [
        "auto_generate",
        "customize",
        "unsupported"
      ]
    },
    "dispatch_ascend": {
      "type": "string"
    },
    "aclnn": {
      "type": "string",
      "description": "JSON array string, e.g. [\"aclnnSoftmax\", \"aclnnCast\"]"
    },
    "aclnn_source": {
      "type": "string"
    },
    "infer": {
      "type": "string"
    },
    "pyboost": {
      "type": "string"
    },
    "kbk": {
      "type": "string"
    },
    "bprop": {
      "type": "string"
    },
    "ut": {
      "type": "string"
    },
    "st": {
      "type": "string"
    },
    "docs_cn": {
      "type": "string"
    },
    "docs_en": {
      "type": "string"
    },
    "infer_evidence": {
      "type": "string"
    },
    "pyboost_evidence": {
      "type": "string"
    },
    "kbk_evidence": {
      "type": "string"
    },
    "bprop_evidence": {
      "type": "string"
    },
    "ut_evidence": {
      "type": "string"
    },
    "st_evidence": {
      "type": "string"
    },
    "docs_cn_evidence": {
      "type": "string"
    },
    "docs_en_evidence": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
