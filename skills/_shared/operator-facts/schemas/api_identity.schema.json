{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "operator-facts api_identity row",
  "type": "object",
  "required": [
    "identity_key",
    "public_api",
    "public_surface",
    "op_branch",
    "op",
    "primitive"
  ],
  "properties": {
    "identity_key": {
      "type": "string",
      "description": "Primary key, composed from public_api and op_branch."
    },
    "public_api": {
      "type": "string"
    },
    "public_surface": {
      "type": "string",
      "enum": [
        "mindspore.ops",
        "mindspore.Tensor",
        "mindspore.mint"
      ]
    },
    "api_name": {
      "type": "string"
    },
    "op_branch": {
      "type": "string"
    },
    "op": {
      "type": "string"
    },
    "primitive": {
      "type": "string"
    },
    "py_method": {
      "type": "string"
    },
    "interface": {
      "type": "string"
    },
    "target_module": {
      "type": "string"
    },
    "target_symbol": {
      "type": "string"
    },
    "resolver_kind": {
      "type": "string"
    },
    "resolver_path": {
      "type": "string"
    },
    "source_file": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
