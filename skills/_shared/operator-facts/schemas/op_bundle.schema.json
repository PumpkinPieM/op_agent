{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "operator-facts ms-centered op bundle v1",
  "description": "MindSpore-centered bundle that stores stable MS facts only. PTA facts remain in the separate pta_facts index, and integration decisions are deferred to pre-stage rule evaluation.",
  "type": "object",
  "required": [
    "bundle_key",
    "bundle_mode",
    "schema_version",
    "generated_at",
    "identity",
    "coverage"
  ],
  "properties": {
    "bundle_key": {
      "type": "string",
      "description": "Primary MS-centered key, composed from public_api and op_branch."
    },
    "bundle_mode": {
      "type": "string",
      "const": "ms_centered"
    },
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "generated_at": {
      "type": "string"
    },
    "identity": {
      "type": "object",
      "required": [
        "public_api",
        "public_surface",
        "api_name",
        "op_branch",
        "op",
        "primitive",
        "interface",
        "target_symbol",
        "py_method",
        "resolver_kind",
        "resolver_path",
        "source_file"
      ],
      "properties": {
        "public_api": {
          "type": "string"
        },
        "public_surface": {
          "type": "string"
        },
        "api_name": {
          "type": "string"
        },
        "op_branch": {
          "type": "string"
        },
        "op": {
          "type": "string"
        },
        "primitive": {
          "type": "string"
        },
        "interface": {
          "type": "string"
        },
        "target_symbol": {
          "type": "string"
        },
        "py_method": {
          "type": "string"
        },
        "resolver_kind": {
          "type": "string"
        },
        "resolver_path": {
          "type": "string"
        },
        "source_file": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "coverage": {
      "type": "object",
      "required": [
        "coverage_key",
        "op_yaml_path",
        "class_name",
        "dispatch_enable",
        "dispatch_kind",
        "dispatch_ascend",
        "aclnn",
        "aclnn_source",
        "infer",
        "pyboost",
        "kbk",
        "bprop",
        "ut",
        "st",
        "docs_cn",
        "docs_en"
      ],
      "properties": {
        "coverage_key": {
          "type": "string"
        },
        "op_yaml_path": {
          "type": "string"
        },
        "class_name": {
          "type": "string"
        },
        "dispatch_enable": {
          "type": "boolean"
        },
        "dispatch_kind": {
          "type": "string",
          "enum": [
            "auto_generate",
            "customize",
            "unsupported"
          ]
        },
        "dispatch_ascend": {
          "type": "string"
        },
        "aclnn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "aclnn_source": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "aclnn_config",
              "auto_generate_source",
              "customize_source"
            ]
          }
        },
        "infer": {
          "type": "boolean"
        },
        "pyboost": {
          "type": "boolean"
        },
        "kbk": {
          "type": "boolean"
        },
        "bprop": {
          "type": "boolean"
        },
        "ut": {
          "type": "boolean"
        },
        "st": {
          "type": "boolean"
        },
        "docs_cn": {
          "type": "boolean"
        },
        "docs_en": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
